# User-specific path config (copy config_template.py → config.py and set your paths)
src/config.py

.DS_Store
*.pyc
src/__pycache__/
calibration/__pycache__/

# Untracked data and results (ignore contents, not the directory itself)
data/*
results/
archive/
products/figures/
products/text/

# Calibration support files
calibration/Technical questions Gemini data loggers and Probes.docx
calibration/Technical questions Gemini data loggers and Probes.pdf
calibration/photos/

# Common output formats (gitignored everywhere except figures/)
*.csv
*.pdf
*.svg
*.png

# Allow tracked paper figures
!/figures/
!/figures/*.pdf
!/figures/*.png

# Allow assets (profile photo, overview map for README)
!/assets/
!/assets/*.png
!/assets/*.jpeg
!/assets/*.jpg

# Allow small metadata files bundled with the repo (MUST come after *.csv rule)
!data/borehole_settings/
!data/borehole_settings/*.csv
!data/glamos/
!data/glamos/mass_balance_cumulative_*.csv
!data/calibration/
!data/calibration/corrected_chain_offsets.csv
